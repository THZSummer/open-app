<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.it.works.wecode.v2.modules.dictionary.mapper.DictionaryMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.xxx.it.works.wecode.v2.modules.dictionary.entity.DictionaryEntity">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="value" property="value"/>
        <result column="description" property="description"/>
        <result column="path" property="path"/>
        <result column="language" property="language"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="last_update_by" property="lastUpdateBy"/>
        <result column="last_update_time" property="lastUpdateTime"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, code, name, value, description, path, language, status,
        create_by, create_time, last_update_by, last_update_time
    </sql>

    <!-- 插入数据字典 -->
    <insert id="insert" parameterType="com.xxx.it.works.wecode.v2.modules.dictionary.entity.DictionaryEntity">
        INSERT INTO openplatform_property_t (
            id, code, name, value, description, path, language, status,
            create_by, create_time, last_update_by, last_update_time
        ) VALUES (
            #{id}, #{code}, #{name}, #{value}, #{description}, #{path}, #{language}, #{status},
            #{createBy}, #{createTime}, #{lastUpdateBy}, #{lastUpdateTime}
        )
    </insert>

    <!-- 根据ID查询数据字典 -->
    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_property_t
        WHERE id = #{id}
    </select>

    <!-- 根据路径和编码查询数据字典 -->
    <select id="selectByPathAndCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_property_t
        WHERE code = #{code}
          AND path = #{path}
    </select>

    <!-- 查询数据字典列表 -->
    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_property_t
        <where>
            <if test="code != null and code != ''">
                AND code LIKE #{code}
            </if>
            <if test="name != null and name != ''">
                AND name LIKE #{name}
            </if>
            <if test="path != null and path != ''">
                AND path LIKE #{path}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
        ORDER BY create_time DESC, id DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 统计数据字典总数 -->
    <select id="countList" resultType="long">
        SELECT COUNT(*)
        FROM openplatform_property_t
        <where>
            <if test="code != null and code != ''">
                AND code LIKE #{code}
            </if>
            <if test="name != null and name != ''">
                AND name LIKE #{name}
            </if>
            <if test="path != null and path != ''">
                AND path LIKE #{path}
            </if>
            <if test="status != null">
                AND status = #{status}
            </if>
        </where>
    </select>

    <!-- 更新数据字典 -->
    <update id="update" parameterType="com.xxx.it.works.wecode.v2.modules.dictionary.entity.DictionaryEntity">
        UPDATE openplatform_property_t
        SET name = #{name},
            value = #{value},
            description = #{description},
            path = #{path},
            <if test="status != null">
                status = #{status},
            </if>
            last_update_time = #{lastUpdateTime},
            last_update_by = #{lastUpdateBy}
        WHERE id = #{id}
    </update>

    <!-- 删除数据字典 -->
    <delete id="deleteById">
        DELETE FROM openplatform_property_t
        WHERE id = #{id}
    </delete>

</mapper>
