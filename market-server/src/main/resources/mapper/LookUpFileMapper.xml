<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.it.works.wecode.v2.modules.lookup.mapper.LookUpFileMapper">

    <resultMap id="BaseResultMap" type="com.xxx.it.works.wecode.v2.modules.lookup.entity.LookUpFileEntity">
        <id column="file_id" property="fileId"/>
        <result column="file_name" property="fileName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_type" property="fileType"/>
        <result column="biz_type" property="bizType"/>
        <result column="create_time" property="createTime"/>
        <result column="last_update_time" property="lastUpdateTime"/>
        <result column="create_by" property="createBy"/>
    </resultMap>

    <sql id="Base_Column_List">
        file_id, file_name, file_path, file_size, file_type, biz_type,
        create_time, last_update_time, create_by
    </sql>

    <insert id="insert" parameterType="com.xxx.it.works.wecode.v2.modules.lookup.entity.LookUpFileEntity"
            useGeneratedKeys="true" keyProperty="fileId">
        INSERT INTO openplatform_lookup_file_t (
            file_name, file_path, file_size, file_type, biz_type,
            create_time, last_update_time, create_by
        ) VALUES (
            #{fileName}, #{filePath}, #{fileSize}, #{fileType}, #{bizType},
            #{createTime}, #{lastUpdateTime}, #{createBy}
        )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_lookup_file_t
        WHERE file_id = #{fileId}
    </select>

    <select id="selectList" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_lookup_file_t
        <where>
            <if test="bizType != null">
                AND biz_type = #{bizType}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{limit}
    </select>

    <delete id="deleteById">
        DELETE FROM openplatform_lookup_file_t
        WHERE file_id = #{fileId}
    </delete>

</mapper>