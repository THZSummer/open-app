<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.it.works.wecode.v2.modules.ability.mapper.AbilityPropertyMapper">

    <resultMap id="BaseResultMap" type="com.xxx.it.works.wecode.v2.modules.ability.entity.AbilityProperty">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="property_name" property="propertyName"/>
        <result column="property_value" property="propertyValue"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="last_update_by" property="lastUpdateBy"/>
        <result column="last_update_time" property="lastUpdateTime"/>
    </resultMap>

    <select id="selectByParentIds" resultMap="BaseResultMap">
        SELECT id,
               parent_id,
               property_name,
               property_value,
               status,
               create_by,
               create_time,
               last_update_by,
               last_update_time
        FROM openplatform_ability_p_t
        WHERE parent_id IN
        <foreach collection="parentIds" item="id" open="(" separator="," close=")">
            #{id,jdbcType=BIGINT}
        </foreach>
        AND status = 1
    </select>

    <!-- ==================== insert ==================== -->
    <!-- 注意：openplatform_ability_p_t.id 无 AUTO_INCREMENT，需手动设置 ID -->
    <insert id="insert"
            parameterType="com.xxx.it.works.wecode.v2.modules.ability.entity.AbilityProperty">
        INSERT INTO openplatform_ability_p_t (
            id, parent_id, property_name, property_value, status,
            create_by, create_time, last_update_by, last_update_time
        ) VALUES (
            #{id}, #{parentId}, #{propertyName}, #{propertyValue}, #{status},
            #{createBy}, #{createTime}, #{lastUpdateBy}, #{lastUpdateTime}
        )
    </insert>

</mapper>
