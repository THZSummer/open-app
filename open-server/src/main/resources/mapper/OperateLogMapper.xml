<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.it.works.wecode.v2.modules.auditlog.mapper.OperateLogMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap"
               type="com.xxx.it.works.wecode.v2.modules.auditlog.entity.OperateLog">
        <id column="id" property="id"/>
        <result column="app_id" property="appId"/>
        <result column="operate_type" property="operateType"/>
        <result column="operate_object" property="operateObject"/>
        <result column="operate_desc_cn" property="operateDescCn"/>
        <result column="operate_desc_en" property="operateDescEn"/>
        <result column="operate_user" property="operateUser"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="before_data" property="beforeData"/>
        <result column="after_data" property="afterData"/>
        <result column="status" property="status"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="last_update_by" property="lastUpdateBy"/>
        <result column="last_update_time" property="lastUpdateTime"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="Base_Column_List">
        id, app_id, operate_type, operate_object,
        operate_desc_cn, operate_desc_en,
        operate_user, ip_address, before_data, after_data, status,
        create_by, create_time, last_update_by, last_update_time
    </sql>

    <!-- 插入操作记录 -->
    <insert id="insert"
            parameterType="com.xxx.it.works.wecode.v2.modules.auditlog.entity.OperateLog">
        INSERT INTO openplatform_operate_log_t (
            id, app_id, operate_type, operate_object,
            operate_desc_cn, operate_desc_en,
            operate_user, ip_address, before_data, after_data, status,
            create_by, create_time, last_update_by, last_update_time
        ) VALUES (
            #{id}, #{appId}, #{operateType}, #{operateObject},
            #{operateDescCn}, #{operateDescEn},
            #{operateUser}, #{ipAddress}, #{beforeData}, #{afterData}, #{status},
            #{createBy}, #{createTime}, #{lastUpdateBy}, #{lastUpdateTime}
        )
    </insert>

    <!-- 通用查询条件 -->
    <sql id="Page_Where">
        <where>
            <if test="appId != null and appId != ''">
                AND app_id = #{appId}
            </if>
            <if test="operateType != null and operateType != ''">
                AND operate_type = #{operateType}
            </if>
            <if test="operateObject != null and operateObject != ''">
                AND operate_object = #{operateObject}
            </if>
            <if test="operateUser != null and operateUser != ''">
                AND operate_user LIKE CONCAT('%', #{operateUser}, '%')
            </if>
            <if test="startTime != null and startTime != ''">
                AND create_time &gt;= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND create_time &lt;= #{endTime}
            </if>
        </where>
    </sql>

    <!-- 分页查询 -->
    <select id="selectPage" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_operate_log_t
        <include refid="Page_Where"/>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 分页计数 -->
    <select id="selectPageCount" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM openplatform_operate_log_t
        <include refid="Page_Where"/>
    </select>

</mapper>
