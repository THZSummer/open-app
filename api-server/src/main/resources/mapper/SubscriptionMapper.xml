<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.xxx.api.common.mapper.SubscriptionMapper">

    <resultMap id="BaseResultMap" type="com.xxx.api.common.entity.Subscription">
        <id column="id" property="id"/>
        <result column="app_id" property="appId"/>
        <result column="permission_id" property="permissionId"/>
        <result column="status" property="status"/>
        <result column="channel_type" property="channelType"/>
        <result column="channel_address" property="channelAddress"/>
        <result column="auth_type" property="authType"/>
        <result column="create_time" property="createTime"/>
        <result column="last_update_time" property="lastUpdateTime"/>
        <result column="create_by" property="createBy"/>
        <result column="last_update_by" property="lastUpdateBy"/>
        <result column="approved_at" property="approvedAt"/>
        <result column="approved_by" property="approvedBy"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, app_id, permission_id, status, channel_type, channel_address, auth_type,
        create_time, last_update_time, create_by, last_update_by, approved_at, approved_by
    </sql>

    <select id="selectByAppIdAndPermissionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_v2_subscription_t
        WHERE app_id = #{appId}
        AND permission_id = #{permissionId}
    </select>

    <select id="selectAuthorizedByAppId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_v2_subscription_t
        WHERE app_id = #{appId}
        AND status = 1
    </select>

    <select id="selectAuthorizedByPermissionId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM openplatform_v2_subscription_t
        WHERE permission_id = #{permissionId}
        AND status = 1
    </select>

    <!-- 根据应用ID和Scope查询回调订阅配置 -->
    <select id="selectCallbackConfigByAppIdAndScope" resultMap="BaseResultMap">
        SELECT s.*
        FROM openplatform_v2_subscription_t s
        INNER JOIN openplatform_v2_permission_t p ON s.permission_id = p.id
        WHERE s.app_id = #{appId}
          AND p.scope = #{scope}
          AND s.status = 1
          AND p.resource_type = 'callback'
    </select>

</mapper>
