<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xxx.api.modules.app.mapper.AppPropertyEntityMapper">

    <resultMap id="BaseResultMap" type="com.xxx.api.modules.app.entity.AppPropertyEntity">
        <id column="id" property="id"/>
        <result column="parent_id" property="parentId"/>
        <result column="property_name" property="propertyName"/>
        <result column="property_value" property="propertyValue"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="selectByEamapAppCode" resultMap="BaseResultMap">
        SELECT id, parent_id, property_name, property_value, tenant_id, status
        FROM openplatform_app_p_t
        WHERE property_name = 'eamap_app_code'
          AND property_value = #{eamapAppCode}
        LIMIT 1
    </select>

</mapper>
