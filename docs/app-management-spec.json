      {"method": "PUT", "endpoint": "/api/v1/users/:id", "description": "Update user"},
      {"method": "DELETE", "endpoint": "/api/v1/users/:id", "description": "Delete user"}
    ],
    "categories": [
      {"method": "GET", "endpoint": "/api/v1/categories", "description": "List categories"},
      {"method": "GET", "endpoint": "/api/v1/categories/:id", "description": "Get category details"},
      {"method": "POST", "endpoint": "/api/v1/categories", "description": "Create category"},
      {"method": "PUT", "endpoint": "/api/v1/categories/:id", "description": "Update category"},
      {"method": "DELETE", "endpoint": "/api/v1/categories/:id", "description": "Delete category"}
    ],
    "tags": [
      {"method": "GET", "endpoint": "/api/v1/tags", "description": "List tags"},
