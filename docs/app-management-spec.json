{
  "documentInfo": {
    "id": "SDD-APP-MGMT-001",
    "title": "App Management Web Application - Software Specification",
    "version": "1.0",
    "created": "2026-03-23",
    "author": "SDD Specification Team",
    "status": "Draft"
  },
  "projectOverview": {
    "purpose": "Build a centralized web platform for managing applications throughout their lifecycle",
    "scope": {
      "inScope": [
        "Web application (Desktop browsers)",
        "Application CRUD operations",
        "Version management",
        "Deployment tracking",
        "User permissions & access control"
      ],
      "outOfScope": [
        "Mobile applications (iOS/Android)",
        "Native mobile app features",
        "Offline capabilities",
        "Desktop client applications"
      ]
    },
    "goals": [
      {
        "id": "BG-001",
        "goal": "Centralize application inventory",
        "successMetric": "100% of applications registered"
      },
      {
        "id": "BG-002",
        "goal": "Improve deployment visibility",
        "successMetric": "Real-time deployment status"
      },
      {
        "id": "BG-003",
        "goal": "Reduce management overhead",
        "successMetric": "50% reduction in manual tracking"
      },
      {
        "id": "BG-004",
        "goal": "Enhance security compliance",
        "successMetric": "Role-based access for all apps"
      }
    ],
    "userPersonas": [
      {
        "name": "System Administrator",
        "description": "Manages overall system configuration",
        "primaryNeeds": ["Full access", "User management", "System settings"]
      },
      {
        "name": "Application Owner",
        "description": "Responsible for specific applications",
        "primaryNeeds": ["CRUD operations", "Version management", "Deployment tracking"]
      },
      {
        "name": "Developer",
        "description": "Builds and maintains applications",
        "primaryNeeds": ["View details", "Update versions", "Check deployment status"]
      },
      {
        "name": "Viewer",
        "description": "Needs read-only access",
        "primaryNeeds": ["Search", "View application details", "Reports"]
      },
      {
        "name": "Auditor",
        "description": "Compliance and security review",
        "primaryNeeds": ["Audit logs", "Access reports", "Change history"]
      }
    ]
  },
  "architecture": {
    "frontendStack": {
      "framework": "React 18.x",
      "language": "TypeScript 5.x",
      "stateManagement": "Redux Toolkit / Zustand",
      "uiLibrary": "Ant Design / MUI",
      "routing": "React Router 6.x",
      "httpClient": "Axios / React Query",
      "formHandling": "React Hook Form",
      "validation": "Zod / Yup",
      "buildTool": "Vite 5.x",
      "testing": "Vitest + React Testing Library",
      "styling": "TailwindCSS + CSS Modules"
    },
    "backendStack": {
      "runtime": "Node.js 20.x LTS",
      "framework": "NestJS 10.x",
      "apiStyle": "REST + GraphQL (optional)",
      "authentication": "JWT + Passport.js",
      "authorization": "CASL / Access Control",
      "validation": "class-validator",
      "documentation": "Swagger/OpenAPI 3.0",
      "testing": "Jest + Supertest",
      "logging": "Winston + Pino"
    },
    "databaseStack": {
      "primaryDb": "PostgreSQL 15.x",
      "orm": "Prisma / TypeORM",
      "cache": "Redis 7.x",
      "search": "PostgreSQL Full-Text / Elasticsearch"
    },
    "entities": [
      {
        "name": "users",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "username", "type": "VARCHAR(50)", "constraints": "UNIQUE, NOT NULL"},
          {"name": "email", "type": "VARCHAR(255)", "constraints": "UNIQUE, NOT NULL"},
          {"name": "password_hash", "type": "VARCHAR(255)", "constraints": "NOT NULL"},
          {"name": "full_name", "type": "VARCHAR(100)", "constraints": ""},
          {"name": "status", "type": "VARCHAR(20)", "constraints": "DEFAULT 'active'"},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"},
          {"name": "updated_at", "type": "TIMESTAMP", "constraints": ""}
        ]
      },
      {
        "name": "applications",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "name", "type": "VARCHAR(100)", "constraints": "NOT NULL"},
          {"name": "description", "type": "TEXT", "constraints": ""},
          {"name": "app_key", "type": "VARCHAR(50)", "constraints": "UNIQUE, NOT NULL"},
          {"name": "category_id", "type": "UUID", "constraints": "FOREIGN KEY"},
          {"name": "owner_id", "type": "UUID", "constraints": "FOREIGN KEY, NOT NULL"},
          {"name": "status", "type": "VARCHAR(20)", "constraints": "DEFAULT 'active'"},
          {"name": "icon_url", "type": "VARCHAR(500)", "constraints": ""},
          {"name": "repository_url", "type": "VARCHAR(500)", "constraints": ""},
          {"name": "documentation_url", "type": "VARCHAR(500)", "constraints": ""},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"},
          {"name": "updated_at", "type": "TIMESTAMP", "constraints": ""},
          {"name": "deleted_at", "type": "TIMESTAMP", "constraints": ""}
        ]
      },
      {
        "name": "app_versions",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "application_id", "type": "UUID", "constraints": "FOREIGN KEY, NOT NULL"},
          {"name": "version_number", "type": "VARCHAR(20)", "constraints": "NOT NULL"},
          {"name": "release_notes", "type": "TEXT", "constraints": ""},
          {"name": "release_date", "type": "TIMESTAMP", "constraints": ""},
          {"name": "is_current", "type": "BOOLEAN", "constraints": "DEFAULT false"},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"},
          {"name": "created_by", "type": "UUID", "constraints": "FOREIGN KEY"}
        ]
      },
      {
        "name": "deployments",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "version_id", "type": "UUID", "constraints": "FOREIGN KEY, NOT NULL"},
          {"name": "environment", "type": "VARCHAR(20)", "constraints": "NOT NULL"},
          {"name": "status", "type": "VARCHAR(20)", "constraints": "DEFAULT 'pending'"},
          {"name": "deployed_at", "type": "TIMESTAMP", "constraints": ""},
          {"name": "deployed_by", "type": "UUID", "constraints": "FOREIGN KEY"},
          {"name": "url", "type": "VARCHAR(500)", "constraints": ""},
          {"name": "health_status", "type": "VARCHAR(20)", "constraints": "DEFAULT 'unknown'"},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"},
          {"name": "updated_at", "type": "TIMESTAMP", "constraints": ""}
        ]
      },
      {
        "name": "categories",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "name", "type": "VARCHAR(100)", "constraints": "NOT NULL"},
          {"name": "parent_id", "type": "UUID", "constraints": "FOREIGN KEY (self-reference)"},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"}
        ]
      },
      {
        "name": "tags",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "name", "type": "VARCHAR(50)", "constraints": "UNIQUE, NOT NULL"},
          {"name": "color", "type": "VARCHAR(20)", "constraints": ""},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"}
        ]
      },
      {
        "name": "audit_logs",
        "columns": [
          {"name": "id", "type": "UUID", "constraints": "PRIMARY KEY"},
          {"name": "user_id", "type": "UUID", "constraints": "FOREIGN KEY"},
          {"name": "action", "type": "VARCHAR(50)", "constraints": "NOT NULL"},
          {"name": "entity_type", "type": "VARCHAR(50)", "constraints": "NOT NULL"},
          {"name": "entity_id", "type": "UUID", "constraints": "NOT NULL"},
          {"name": "old_value", "type": "JSONB", "constraints": ""},
          {"name": "new_value", "type": "JSONB", "constraints": ""},
          {"name": "ip_address", "type": "VARCHAR(45)", "constraints": ""},
          {"name": "created_at", "type": "TIMESTAMP", "constraints": "DEFAULT NOW()"}
        ]
      }
    ]
  },
  "apiEndpoints": {
