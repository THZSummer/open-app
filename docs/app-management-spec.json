      {"method": "DELETE", "endpoint": "/api/v1/tags/:id", "description": "Delete tag"}
    ],
    "audit": [
      {"method": "GET", "endpoint": "/api/v1/audit-logs", "description": "List audit logs"},
      {"method": "GET", "endpoint": "/api/v1/audit-logs/:entityType/:entityId", "description": "Get entity audit history"}
    ]
  },
  "coreFeatures": {
    "functionalRequirements": [
      {
        "id": "FR-001",
        "name": "Create Application",
        "description": "Users can register new applications in the system",
        "requirements": [
          "System shall provide a form for entering application details",
          "System shall validate application name uniqueness",
          "System shall generate a unique application key automatically",
          "System shall require at minimum: name, description, owner",
          "System shall allow optional fields: icon, repository URL, documentation URL",
          "System shall assign default status as 'active'"
        ]
      },
      {
        "id": "FR-002",
        "name": "Read Application",
        "description": "Users can view application details",
        "requirements": [
          "System shall display complete application information",
          "System shall show associated versions list",
          "System shall show deployment history",
          "System shall display tags and categories",
          "System shall show audit history (for authorized users)"
        ]
      },
      {
        "id": "FR-003",
        "name": "Update Application",
        "description": "Users can modify application information",
        "requirements": [
          "System shall allow editing all mutable fields",
          "System shall prevent changing app_key after creation",
          "System shall log all changes to audit log",
          "System shall validate permissions before update",
          "System shall update the updated_at timestamp"
        ]
      },
      {
        "id": "FR-004",
        "name": "Delete Application",
        "description": "Users can remove applications from the system",
        "requirements": [
          "System shall implement soft delete (deleted_at field)",
          "System shall require confirmation before deletion",
          "System shall check for active deployments before deletion",
          "System shall archive associated versions and deployments",
          "System shall log deletion to audit log",
          "System shall restrict delete permission to owners/admins"
        ]
      },
      {
        "id": "FR-005",
        "name": "Application List",
        "description": "Display paginated list of applications",
        "requirements": [
          "System shall display applications in a table or card view",
          "System shall support pagination (default 20 items per page)",
          "System shall allow sorting by name, created date, updated date",
          "System shall show application status indicator",
          "System shall display key information: name, owner, category, status"
        ]
      },
      {
        "id": "FR-006",
        "name": "Search and Filter",
        "description": "Users can search and filter applications",
        "requirements": [
          "System shall provide full-text search across name and description",
          "System shall support filtering by category",
          "System shall support filtering by status",
          "System shall support filtering by owner",
          "System shall support filtering by tags",
          "System shall support date range filtering (created/updated)",
          "System shall preserve filters across pagination",
          "System shall support saving filter presets"
        ]
      },
      {
        "id": "FR-007",
        "name": "Application Details View",
        "description": "Display comprehensive application details",
        "requirements": [
          "System shall display application metadata in header section",
          "System shall show version timeline",
          "System shall display deployment status by environment",
          "System shall show related links (repo, docs)",
          "System shall display tags and categories",
          "System shall show ownership and permission information"
        ]
      },
      {
        "id": "FR-008",
        "name": "Category Management",
        "description": "Organize applications using hierarchical categories",
        "requirements": [
          "System shall support hierarchical categories (parent/child)",
          "System shall allow creating, editing, and deleting categories",
          "System shall prevent deletion of categories with assigned applications",
          "System shall allow applications to have primary and secondary categories",
          "System shall provide default system categories"
        ]
      },
      {
        "id": "FR-009",
        "name": "Tag Management",
        "description": "Flexible tagging system for cross-category organization",
        "requirements": [
          "System shall support adding multiple tags to applications",
          "System shall support tag colors for visual organization",
          "System shall provide tag autocomplete/suggestions",
          "System shall prevent duplicate tags",
          "System shall allow tag cleanup/merging"
        ]
      },
      {
        "id": "FR-010",
        "name": "Role-Based Access Control",
        "description": "Implement RBAC for system access",
        "requirements": [
          "System shall enforce role-based permissions on all endpoints",
          "System shall support multiple roles per user",
          "System shall support application-level permissions",
          "System shall provide permission inheritance (owner > developer > viewer)",
          "System shall log permission changes"
        ]
      },
      {
        "id": "FR-011",
        "name": "Application Permissions",
        "description": "Granular permissions at application level",
        "requirements": [
          "Permission matrix enforcement for Owner/Developer/Viewer roles",
          "View/Edit/Delete/Create Version/Deploy/Manage Permissions access control"
        ]
      },
      {
        "id": "FR-012",
        "name": "Version Tracking",
        "description": "Track application versions using semantic versioning",
        "requirements": [
          "System shall support semantic versioning (MAJOR.MINOR.PATCH)",
          "System shall validate version number format",
          "System shall prevent duplicate versions for same application",
          "System shall track version creation metadata (who, when)",
          "System shall support release notes for each version",
          "System shall identify current production version",
          "System shall maintain version history"
        ]
      },
      {
        "id": "FR-013",
        "name": "Deployment Management",
        "description": "Track application deployments across environments",
        "requirements": [
          "System shall support multiple environments (dev, staging, production)",
          "System shall track deployment status (pending, success, failed, rolling_back)",
          "System shall record deployment metadata (who, when, version)",
          "System shall track deployment URL per environment",
          "System shall support health status tracking",
          "System shall maintain deployment history",
          "System shall support deployment rollback tracking"
        ]
      },
      {
        "id": "FR-014",
        "name": "Deployment Visualization",
        "description": "Visual representation of deployment status",
        "requirements": [
          "System shall display deployment pipeline visualization",
          "System shall show environment-specific status indicators",
          "System shall provide deployment timeline",
          "System shall highlight current production version"
        ]
      }
    ]
  },
  "roles": {
    "definitions": [
      {
        "name": "Super Admin",
        "permissions": ["Full system access", "User management", "System configuration"]
      },
      {
        "name": "Admin",
        "permissions": ["Application management", "User assignment", "Audit access"]
      },
      {
        "name": "Application Owner",
        "permissions": ["Full CRUD on owned applications", "Version management"]
      },
      {
        "name": "Developer",
        "permissions": ["Read access", "Version creation", "Deployment updates"]
      },
      {
        "name": "Viewer",
        "permissions": ["Read-only access to applications"]
      }
    ]
  },
