      {"method": "DELETE", "endpoint": "/api/v1/applications/:id", "description": "Delete application"},
      {"method": "GET", "endpoint": "/api/v1/applications/:id/versions", "description": "List versions"},
      {"method": "GET", "endpoint": "/api/v1/applications/:id/deployments", "description": "List deployments"}
    ],
    "versions": [
      {"method": "GET", "endpoint": "/api/v1/versions", "description": "List versions"},
      {"method": "GET", "endpoint": "/api/v1/versions/:id", "description": "Get version details"},
      {"method": "POST", "endpoint": "/api/v1/versions", "description": "Create version"},
      {"method": "PUT", "endpoint": "/api/v1/versions/:id", "description": "Update version"},
      {"method": "DELETE", "endpoint": "/api/v1/versions/:id", "description": "Delete version"}
    ],
    "deployments": [
