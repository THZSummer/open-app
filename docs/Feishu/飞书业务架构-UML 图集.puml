## 1. 组件图 (Component Diagram)

```plantuml
@startuml 飞书业务架构组件图

skinparam componentStyle rectangle
skinparam packageStyle rectangle

package "用户层 <<Users>>" {
  [普通用户] as User
  [管理员] as Admin
  [开发者] as Developer
}

package "应用层 <<Applications>>" {
  component "自建应用\nCustom App" as CustomApp #E8F5E9
  component "商店应用\nStore App" as StoreApp #E8F5E9
}

package "认证授权层 <<Authentication>>" {
  database "app_access_token\n(2 小时)" as AppToken #F3E5F5
  database "tenant_access_token\n(2 小时)" as TenantToken #F3E5F5
  database "user_access_token\n(OAuth 2.0)" as UserToken #F3E5F5
}

package "事件层 <<Events>>" {
  queue "用户事件\ncontact.*" as UserEvent #FFEBEE
  queue "消息事件\nim.*" as MsgEvent #FFEBEE
  queue "应用事件\napp.*" as AppEvent #FFEBEE
