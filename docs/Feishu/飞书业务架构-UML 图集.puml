## 3. 活动图 - user_access_token 获取流程 (OAuth 2.0)

```plantuml
@startuml user_access_token OAuth2 流程

skinparam sequence {
  LifeLineBackgroundColor #E3F2FD
  LifeLineBorderColor #1976D2
}

start

:用户访问应用;

partition "步骤 1: 授权" {
  :重定向到飞书授权页面;
  :https://open.feishu.cn/authen/v1/authorize;
  :参数：app_id, redirect_uri, state;
  
  :用户登录飞书;
  :用户同意授权;
}

:飞书重定向回应用;
:URL: redirect_uri?code=xxxxx;

partition "步骤 2: 换取 Token" {
  :POST /authen/v1/access_token;
  :Request Body:\n{\n  "grant_type": "authorization_code",\n  "code": "xxxxx"\n};
}

if (验证通过？) then (是)
  :获取 user_access_token;
  :获取 refresh_token;
  :access_token 可调用用户 API;
  :refresh_token 用于刷新;
else (否)
  :授权失败;
  stop
endif

partition "步骤 3: 调用 API" {
  :GET /open-apis/contact/v3/users/{user_id};
  :Header: Authorization: Bearer <token>;
}

if (token 过期？) then (是)
  :POST /authen/v1/refresh_access_token;
  :参数：refresh_token;
  :获取新 user_access_token;
else (否)
  :继续使用;
endif

stop

@enduml
```

