## 2. 活动图 - app_access_token 获取流程

```plantuml
@startuml app_access_token 获取流程

skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1976D2
}
skinparam condition {
  BackgroundColor #FFF3E0
  BorderColor #F57C00
}

start

:创建自建应用;
:获取 app_id;
:获取 app_secret;

partition "API 调用" {
  :POST /open-apis/auth/v3/\napp_access_token/internal;
  :Request Body:\n{\n  "app_id": "cli_xxxxx",\n  "app_secret": "xxxxx"\n};
}

if (响应 code == 0?) then (是)
  :获取 app_access_token;
  :有效期 2 小时;
  :缓存到服务端;
  
  if (剩余有效期 < 30 分钟？) then (是)
    :调用刷新接口;
    :获取新 token;
  else (否)
    :使用现有 token;
  endif
  
  :调用业务 API;
else (否)
  :检查错误码;
  if (99991401?) then (IP 错误)
    :配置 IP 白名单;
  elseif (99991663?) then (凭证错误)
    :检查 app_id/secret;
  else (其他错误)
    :查看错误文档;
  endif
  stop
endif

stop

@enduml
```

