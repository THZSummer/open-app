}

node "飞书开放平台云平台" #E3F2FD {
  node "认证服务集群" {
    component "Token 颁发" as AuthIssue
    component "OAuth2 服务" as OAuth2
    component "权限验证" as AuthCheck
  }
  
  node "API 网关集群" {
    component "请求路由" as Router
    component "限流熔断" as RateLimit
    component "日志审计" as Audit
  }
  
  node "业务服务集群" {
    component "通讯录服务" as ContactSvc
    component "消息服务" as MsgSvc
    component "云文档服务" as DriveSvc
    component "日历服务" as CalSvc
  }
  
  node "事件推送服务" {
    component "事件捕获" as EventCapture
    component "消息队列" as MQ
    component "推送网关" as PushGW
  }
  
  database "租户数据库" as TenantDB
}

node "企业网络" #E8F5E9 {
  node "开发者服务器" {
    component "应用后端" as AppBackend
    database "Token 缓存\n(Redis)" as TokenCache
    component "事件处理器" as EventHandler
