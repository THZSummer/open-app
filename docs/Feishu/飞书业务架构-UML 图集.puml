## 6. 类图 - Token 管理核心类

```plantuml
@startuml Token 管理类图

skinparam classAttributeIconSize 0

class TokenManager {
  -app_id: String
  -app_secret: String
  -cache: ConcurrentHashMap<String, TokenInfo>
  -refresh_threshold: int = 1800
  
  +getAppAccessToken(): String
  +getTenantAccessToken(): String
  +getUserAccessToken(code: String): String
  +refreshUserToken(refresh_token: String): String
  -fetchToken(type: String, params: Map): TokenInfo
  -isTokenValid(token: String): boolean
  -shouldRefresh(token: TokenInfo): boolean
}

class TokenInfo {
  +token: String
  +refresh_token: String
  +expire_in: int
  +created_at: long
  +token_type: String
  
  +getExpireTime(): long
  +isExpired(): boolean
  +remainingSeconds(): long
  +shouldRefresh(threshold: int): boolean
}

class APIClient {
  -base_url: String = "https://open.feishu.cn"
  -tokenManager: TokenManager
  -timeout: int = 5000
  
  +getUserInfo(user_id: String): UserInfo
  +sendMessage(chat_id: String, content: String): Message
  +getDocList(folder_id: String): List<Document>
  +createCalendarEvent(calendar_id: String, event: Event): Event
  -executeRequest(method: String, path: String, body: Object): Response
  -handleError(response: Response): FeishuException
}

class FeishuException {
  +code: int
  +message: String
  +request_id: String
  
  +isTokenExpired(): boolean
  +isPermissionDenied(): boolean
  +isRateLimited(): boolean
}

' 关系
TokenManager "1" *-- "many" TokenInfo : 管理 >
APIClient "1" *-- "1" TokenManager : 使用 >
APIClient ..> FeishuException : 抛出 >

note bottom of TokenManager
  <b>刷新策略</b>
  - 剩余有效期 < 30 分钟时刷新
  - 同时最多存在 2 个有效 token
  - 服务端加密存储
  - 线程安全缓存
end note

note right of APIClient
  <b>安全特性</b>
  - 自动 Token 管理
  - 错误重试机制
  - 请求限流
  - 日志记录
end note

@enduml
```

